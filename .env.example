# =========================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =========================================================================
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# =========================================================================
# VIDEO CONFERENCING - LIVEKIT
# =========================================================================
# LiveKit Cloud URL (e.g., wss://your-project.livekit.cloud)
# Get from: https://cloud.livekit.io/projects
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit API Key and Secret are stored as Supabase Edge Function secrets only
# ⚠️  DO NOT store in this client .env file
# Configure in Supabase → Edge Functions → Secrets:
#   - LIVEKIT_API_KEY=your-api-key
#   - LIVEKIT_API_SECRET=your-api-secret
# See: supabase/functions/create-livekit-token/index.ts

# =========================================================================
# APPLICATION ENVIRONMENT
# =========================================================================
VITE_APP_ENV=development

# =========================================================================
# OPTIONAL: ERROR TRACKING & MONITORING
# =========================================================================
# Uncomment and configure when ready to set up production monitoring
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# VITE_POSTHOG_KEY=your-posthog-api-key
